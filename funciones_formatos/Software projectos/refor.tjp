 * PLAN BASICO SOCIO-ECOSISTEMICO
 * ================================
 */

task t1 "Plan Basico Socio-Ecosistemico" {
    task t1a "Socializacion" {
        effort 1m
        #depends !trp.ti
        #depende xx {'gapduration', 'gaplength', 'onend', 'onstart'}
        allocate antro1
        allocate gest1

        #allocate manager {'alternative', 'limits', 'select', 'persistent', 'mandatory', 'shift', 'shifts'}
        #warn ~ 5000        
        #charge 61740860 onstart #onend 
        limits {
          weeklymax 4d
        }
      }

    task t1b "Sensibilizacion" {
        effort 1m
        depends !t1a
        #depende xx {'gapduration', 'gaplength', 'onend', 'onstart'}
