/* 
 * ================================
 * RESTAURACION PARTICIPATIVA
 * ================================
 */
task trp "Restauración Participativa" {
  chargeset productCost

  task ti "Inicio de Actividades Rehabilitación Multifuncional" {
      milestone
      journalentry 2026-03-16 "Para agregar issuues" {
        summary -8<-
          Resumen del issuue.
        ->8-
        details -8<-
          Detalle del issuue.
        ->8- 
        }
    }


